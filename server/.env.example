# Copia este ficheiro para .env e preenche os valores.

# ── Base de dados (Postgres) — OBRIGATÓRIO ─────────────────────────────────
# Connection string do Postgres. Funciona com Neon (neon.tech) ou Supabase.
# Exemplos:
#   Neon:     postgres://utilizador:senha@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
#   Supabase: postgres://postgres:senha@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# ── Leitura de talões por IA (OPCIONAL) ────────────────────────────────────
# Sem isto, a app usa o OCR do telemóvel (grátis). Com chave, usa a IA (melhor).
# Obtém em https://console.anthropic.com/ -> Settings -> API Keys
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Outros (OPCIONAL) ──────────────────────────────────────────────────────
# PORT=3001
