# Copia este ficheiro para .env e preenche a chave.
# Obtém a chave em https://console.anthropic.com/ -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Modelo com visão a usar para ler talões. Por omissão: claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-sonnet-4-6

# (Opcional) Porta da API. Por omissão: 3001
# PORT=3001

# (Opcional) Caminho do ficheiro SQLite (útil em hosts com disco persistente)
# DB_PATH=/data/despesas.db
